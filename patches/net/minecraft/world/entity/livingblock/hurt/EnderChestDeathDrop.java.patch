+package net.minecraft.world.entity.livingblock.hurt;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.sounds.SoundEvents;
+import net.minecraft.sounds.SoundSource;
+import net.minecraft.world.damagesource.DamageSource;
+import net.minecraft.world.entity.livingblock.LivingBlock;
+import net.minecraft.world.entity.player.Player;
+import net.minecraft.world.item.ItemStack;
+
+public class EnderChestDeathDrop implements OnHurt {
+    @Override
+    public void apply(LivingBlock livingBlock, ServerLevel level, DamageSource source, float damage, boolean fatalDamage) {
+        if (!fatalDamage && source.getEntity() instanceof Player player) {
+            BlockPos pos = livingBlock.getOnPos().above();
+            for (int i = player.getEnderChestInventory().getContainerSize() - 1; i >= 0; i--) {
+                ItemStack stack = player.getEnderChestInventory().getItem(i);
+                if (!stack.isEmpty()) {
+                    LivingBlock.createStack(level, pos, player, stack);
+                    player.getEnderChestInventory().setItem(i, ItemStack.EMPTY);
+                    level.playSound(null, livingBlock.getOnPos(), SoundEvents.ENDERMAN_TELEPORT, SoundSource.BLOCKS, 1.0F, 1.0F);
+                    return;
+                }
+            }
+        }
+    }
+}
