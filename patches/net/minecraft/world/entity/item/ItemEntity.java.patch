+    public ItemEntity(net.minecraft.world.level.Level level, double x, double y, double z, net.minecraft.world.item.ItemStack itemStack, double deltaX, double deltaY, double deltaZ) {
+        this(net.minecraft.world.entity.EntityType.LIVING_BLOCK, level);
+        this.setPos(x, y, z);
+        this.setItem(itemStack);
+        this.setDeltaMovement(deltaX, deltaY, deltaZ);
+        this.lifespan = (itemStack.getItem() == null ? LIFETIME : itemStack.getEntityLifespan(level));
