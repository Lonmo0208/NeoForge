+    @Override
+    protected void addAdditionalSaveData(net.minecraft.world.level.storage.ValueOutput output) {
+        output.putShort("Health", (short)this.health);
+        output.putShort("Age", (short)this.age);
+        output.putShort("PickupDelay", (short)this.pickupDelay);
+        output.putInt("Lifespan", this.lifespan);
+        net.minecraft.world.entity.EntityReference.store(this.thrower, output, "Thrower");
+        output.storeNullable("Owner", net.minecraft.core.UUIDUtil.CODEC, this.target);
+        if (!this.getItem().isEmpty()) {
+            output.store("Item", net.minecraft.world.item.ItemStack.CODEC, this.getItem());
+        }
+    }
+
+    @Override
+    protected void readAdditionalSaveData(net.minecraft.world.level.storage.ValueInput input) {
+        this.health = input.getShortOr("Health", (short)5);
+        this.age = input.getShortOr("Age", (short)0);
+        this.pickupDelay = input.getShortOr("PickupDelay", (short)0);
+        this.lifespan = input.getIntOr("Lifespan", ItemEntity.LIFETIME);
+        this.target = input.read("Owner", net.minecraft.core.UUIDUtil.CODEC).orElse(null);
+        this.thrower = net.minecraft.world.entity.EntityReference.read(input, "Thrower");
+        this.setItem(input.read("Item", net.minecraft.world.item.ItemStack.CODEC).orElse(net.minecraft.world.item.ItemStack.EMPTY));
+        if (this.getItem().isEmpty()) {
+            this.discard();
+        }
+    }
+
+    @Override
+    public void playerTouch(net.minecraft.world.entity.player.Player player) {
+        if (!this.level().isClientSide()) {
+            if (!net.minecraft.world.entity.Mob.LIVINGBLOCK_ITEMS_PICKABLE && this.thrower == null) {
+                return;
+            }
+            net.minecraft.world.item.ItemStack itemStack = this.getItem();
+            net.minecraft.world.item.Item item = itemStack.getItem();
+            int orgCount = itemStack.getCount();
+
+            if (this.pickupDelay > 0 && this.target != null && !this.target.equals(player.getUUID())) {
+                return;
+            }
+
+            if (player.getInventory().add(itemStack)) {
+                player.take(this, orgCount);
+                if (itemStack.isEmpty()) {
+                    this.discard();
+                    itemStack.setCount(orgCount);
+                }
+
+                player.awardStat(net.minecraft.stats.Stats.ITEM_PICKED_UP.get(item), orgCount);
+            }
+        }
+    }
