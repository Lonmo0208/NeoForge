+    /**
+     * Converts a snapshot version string (e.g. "26w14a") to a purely numeric version string
+     * (e.g. "26.1.14") for use as the internal id(). The snapshot's week number is used as
+     * the patch version. This ensures mods like VersionResolver that use Integer.parseInt on
+     * version components don't crash on non-numeric snapshot identifiers.
+     * The name() method returns "26.1.2" for mod compatibility, while in-game displays use
+     * DISPLAY_NAME ("26w14a").
+     */
+    private static String snapshotToNumeric(String version) {
+        if (version != null && version.matches("\\d+w\\d+[a-z]")) {
+            String year = version.replaceAll("w\\d+[a-z].*", "");
+            String weekNum = version.replaceAll(".*w(\\d+).*", "$1");
+            return year + ".1." + weekNum;
+        }
+        return version;
+    }
